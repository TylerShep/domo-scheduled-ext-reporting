# =============================================================================
# domo-scheduled-ext-reporting -- Example environment configuration
# =============================================================================
# Copy this file to ".env.local" (or ".env.prod") and fill in real values.
# The active file is selected by APP_ENV (default: "local").
#
#   cp .env.example .env.local
#
# This file is loaded automatically by python-dotenv at startup.
# =============================================================================


# ---- App environment ----
# One of: local | dev | prod
APP_ENV=local


# ---- Domo (required) ----
# Your Domo instance domain, without the protocol (e.g., "mycompany.domo.com").
DOMO_INSTANCE=

# A Domo developer access token. Create one at:
#   <DOMO_INSTANCE>/admin/security/accesstokens
DOMO_TOKEN=

# Dataset ID of the metadata dataset that holds card->page->URL mappings.
# Required columns (case sensitive): CardID, CardName, CardURL, PageID, PageTItle
# Tip: build this dataset once via the Domo Governance APIs or a manual
# Workbench job and reuse it across all your reports.
DOMO_CARDS_META_DATASET_ID=


# ---- Slack (optional -- only needed for slack destinations) ----
# Bot User OAuth Token from your Slack app. Required scopes:
#   channels:read, groups:read, chat:write, files:write
# https://api.slack.com/apps -> your app -> "OAuth & Permissions"
SLACK_BOT_USER_TOKEN=


# ---- Microsoft Teams (optional -- only needed for teams destinations) ----
# Used by destinations that set `auth_mode: graph` in their YAML.
# Create an Azure AD app registration with application permissions:
#   ChannelMessage.Send, Files.ReadWrite.All, Group.Read.All
TEAMS_TENANT_ID=
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=

# Used by destinations that set `auth_mode: webhook` in their YAML.
# Each destination references a *named* webhook env var via `webhook_url_env`,
# so you can have multiple webhooks. Examples:
TEAMS_WEBHOOK_URL=
# TEAMS_SALES_WEBHOOK=https://outlook.office.com/webhook/...
# TEAMS_OPS_WEBHOOK=https://outlook.office.com/webhook/...


# ---- Logging (optional) ----
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Set to a path to also write rotating log files. Leave empty for stdout-only.
LOG_FILE=
