# =============================================================================
# domo-scheduled-ext-reporting -- Example environment configuration
# =============================================================================
# Copy this file to ".env.local" (or ".env.prod") and fill in real values.
# The active file is selected by APP_ENV (default: "local").
#
#   cp .env.example .env.local
#
# This file is loaded automatically by python-dotenv at startup.
# =============================================================================


# ---- App environment ----
# One of: local | dev | prod
APP_ENV=local


# ---- Engine selection (Wave 1) ----
# Which Domo backend to talk to:
#   rest -- native HTTPS via the Domo public REST API (default, no JRE needed)
#   jar  -- shells out to the bundled domoUtil.jar (legacy, requires Java)
#   auto -- pick rest if DOMO_CLIENT_ID/SECRET are set, else jar if java is on PATH
DOMO_ENGINE=rest

# Domo REST API host. Override only if you've been issued a non-default endpoint.
DOMO_API_HOST=api.domo.com


# ---- Domo (REST engine -- recommended) ----
# Create an OAuth client at:
#   https://developer.domo.com/portal/manage/clients
# Required scopes: data, user, dashboard
DOMO_CLIENT_ID=
DOMO_CLIENT_SECRET=


# ---- Domo (JAR engine -- only needed if DOMO_ENGINE=jar) ----
# Your Domo instance domain, without the protocol (e.g., "mycompany.domo.com").
DOMO_INSTANCE=

# A Domo developer access token. Create one at:
#   <DOMO_INSTANCE>/admin/security/accesstokens
DOMO_TOKEN=

# Optional: override the URL that `domo-report --download-jar` pulls from.
# The SHA-256 pinned in app/engines/JAR_VERSION.json is *still* enforced --
# this is only useful if your network blocks github.com.
# DOMO_JAR_URL=https://corp.example.com/artifacts/domoUtil.jar


# ---- Card metadata dataset (required by both engines) ----
# Dataset ID of the metadata dataset that holds card->page->URL mappings.
# Required columns (case sensitive): CardID, CardName, CardURL, PageID, PageTItle
# Tip: build this dataset once via the Domo Governance APIs or a manual
# Workbench job and reuse it across all your reports.
DOMO_CARDS_META_DATASET_ID=


# ---- Slack (optional -- only needed for slack destinations) ----
# Bot User OAuth Token from your Slack app. Required scopes:
#   channels:read, groups:read, chat:write, files:write
#   reactions:write          (Wave 9: react_on_send)
#   chat:write.scheduled     (Wave 9: schedule_at)
# https://api.slack.com/apps -> your app -> "OAuth & Permissions"
SLACK_BOT_USER_TOKEN=


# ---- Microsoft Teams (optional -- only needed for teams destinations) ----
# Used by destinations that set `auth_mode: graph` in their YAML.
# Create an Azure AD app registration with application permissions:
#   ChannelMessage.Send, Files.ReadWrite.All, Group.Read.All
TEAMS_TENANT_ID=
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=

# Used by destinations that set `auth_mode: webhook` in their YAML.
# Each destination references a *named* webhook env var via `webhook_url_env`,
# so you can have multiple webhooks. Examples:
TEAMS_WEBHOOK_URL=
# TEAMS_SALES_WEBHOOK=https://outlook.office.com/webhook/...
# TEAMS_OPS_WEBHOOK=https://outlook.office.com/webhook/...


# ---- Email (optional -- only needed for email destinations, Wave 4) ----
# Standard SMTP. Per-destination env keys can override these defaults.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_ADDR=


# ---- Run history backend (Wave 2) ----
# One of: sqlite | postgres | null
RUN_HISTORY_BACKEND=sqlite

# Path to the SQLite file (created on first run). Default: app/state/runs.db
RUN_HISTORY_DB_PATH=

# Postgres DSN (only used when RUN_HISTORY_BACKEND=postgres).
# Example: postgresql://user:pass@host:5432/domo_reports
RUN_HISTORY_POSTGRES_DSN=


# ---- Card auto-discovery cache (Wave 6) ----
# How long (seconds) to cache list_cards() results.
DISCOVERY_CACHE_TTL_SECONDS=3600


# ---- Web UI (Wave 13) ----
# Requires the [web] extras: pip install "domo-scheduled-ext-reporting[web]".
# Start with: python main.py --serve
DOMO_WEB_HOST=127.0.0.1
DOMO_WEB_PORT=8080

# Admin login. Either set an Argon2id hash (preferred) OR a plaintext password
# (development only). Generate a hash with:
#   python -c "from app.web.auth import hash_password; print(hash_password('s3cret'))"
DOMO_WEB_ADMIN_USER=admin
DOMO_WEB_ADMIN_PASSWORD_HASH=
# DOMO_WEB_ADMIN_PASSWORD=change-me-in-dev-only

# Signed session cookie TTL (seconds) and name. A random secret is generated per
# boot by default -- set DOMO_WEB_SESSION_SECRET to pin it across restarts.
DOMO_WEB_SESSION_TTL=28800
DOMO_WEB_SESSION_SECRET=

# Override the directory the UI reads/writes YAML reports to. Defaults to the
# repo's config/reports folder.
# DOMO_WEB_REPORTS_DIR=/opt/domo-reports/config/reports

# Disable the "Test destination" action (set to 0 to block dry-run prepare()).
DOMO_WEB_ALLOW_DESTINATION_TESTS=1


# ---- Observability (Wave 2) ----
# If set, expose Prometheus metrics on this port.
METRICS_PORT=


# ---- Logging (optional) ----
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Set to a path to also write rotating log files. Leave empty for stdout-only.
LOG_FILE=
